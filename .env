OLLAMA_BASE_URL=https://ollama.viridian.ise.utk.edu
OLLAMA_USERNAME=ollama_user
OLLAMA_AUTH=ollama_user:ollama4Viridian

# Local Ollama instance (confirmed on port 11434)
OLLAMA_LOCAL_URL=http://localhost:11434

# Neo4j — bolt://localhost:7687 is already running on this shared system
# Update NEO4J_PASSWORD to match your instance credentials
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password